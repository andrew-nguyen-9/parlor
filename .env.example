# ═══════════════════════════════════════════════════════════════
# ROOT .env  — pipeline secrets (Python ingest scripts only)
# Copy this to .env and fill in values.
# ═══════════════════════════════════════════════════════════════

# ── Neon write role (pipeline) ────────────────────────────────
# Used by psycopg2 in pipeline/common.py (INSERT/UPDATE rights).
# Get a free connection string at https://neon.tech →
#   project → Connection Details
CONNECTION_STRING=

# ── TMDB (pipeline-only) ──────────────────────────────────────
TMDB_API_KEY=
TMDB_API_READ_ACCESS_TOKEN=

# ═══════════════════════════════════════════════════════════════
# FRONTEND — copy these into frontend/.env.local (gitignored)
# Also set them in Vercel → Project → Environment Variables.
# ═══════════════════════════════════════════════════════════════

# Neon read role — Server Components only, never shipped to browser.
# For a quick start use the same CONNECTION_STRING value above.
# For production, create a READ-ONLY Neon role (least privilege).
DATABASE_URL=

# Supabase — drives The Lobby (Realtime) + global leaderboard.
# Leave blank → Lobby shows an offline notice, scores stay local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Maps JS API (optional) — without this The Map uses the
# offline SVG world atlas instead. No cost either way.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
